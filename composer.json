{
    "name": "velabuild/core",
    "description": "A full-featured AI Optimised CMS admin system, page builder, and content management package for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Mark Walker",
            "email": "m@awcode.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/auth": "^10.0|^11.0",
        "illuminate/notifications": "^10.0|^11.0",
        "spatie/laravel-medialibrary": "^11.0",
        "yajra/laravel-datatables-oracle": "^10.3|^11.0",
        "mcamara/laravel-localization": "^2.3",
        "nuovo/spreadsheet-reader": "^0.5.11",
        "guzzlehttp/guzzle": "^7.2",
        "matthiasmullie/minify": "^1.3"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "VelaBuild\\Core\\": "src/",
            "VelaBuild\\Core\\Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "src/Helpers/template.php",
            "src/Helpers/image.php",
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "VelaBuild\\Core\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VelaBuild\\Core\\VelaServiceProvider"
            ],
            "aliases": {
                "Vela": "VelaBuild\\Core\\Facades\\Vela"
            }
        }
    },
    "minimum-stability": "stable"
}
